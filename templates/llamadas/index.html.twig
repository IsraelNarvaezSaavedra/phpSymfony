{% extends 'base.html.twig' %}
{% import "llamadas/index.html.twig" as macros %}
{% block title %}Configuracion de llamadas
{% endblock %}

{% block stylesheets %}
{% endblock %}

{% block body %}
	<div class="min-vh-100 d-flex flex-column justify-content-center align-items-center py-5" style="width: 1200px; width: 100%;">

		<h1 class="display-4 fw-bold mb-5 text-dark">Recibir Llamada</h1>

		{% for error in app.flashes('error') %}
			<div class="alert alert-danger" role="alert">{{ error }}</div>
		{% endfor %}
		{{ form_errors(configForm) }}
		{{ form_start(configForm) }}
		<div class="d-none">
			{{ form_widget(configForm.tipoLlamada[0], {
				'label': false,
				attr: { class: 'radio_anonimo tipo_llamada' }
			}) }}
			 {{ form_widget(configForm.tipoLlamada[1], {
				'label': false,
				attr: { class: 'radio_clientes tipo_llamada' }
			}) }}
			{{ form_widget(configForm.tipoLlamada[2], {
				'label': false,
				attr: { class: 'radio_no_clientes tipo_llamada' }
			}) }}

			
			{{ form_widget(configForm.tipoInteraccion[0],
			 { 'label': false, attr: { class: 'radio_ia tipo_interaccion' } }) 
			 }}
			{{ form_widget(configForm.tipoInteraccion[1],
			 { 'label': false, attr: { class: 'radio_teclado tipo_interaccion' } })
			  }}
		</div>

		<div class="bg-light p-2 rounded-5 shadow mb-4">
			<div class=" nav nav-pills nav-fill" id="pills-tab" role="tablist" style="width: 1200px; width: 100%;">
				<a href="{{ path('app_webhook_inicio', {tipo: 'anonimo'}) }}" id="anonimo" class=" {{ tipoUsuarioActual == 'anonimo' ? 'active' : '' }} nav-link rounded-5 py-2 d-flex justify-content-center align-items-center gap-1" type="button">
					<svg width="28" height="28" viewbox="0 0 24 24" fill="currentColor">
						<path d="M12 3.2a8.8 8.8 0 1 0 0 17.6 8.8 8.8 0 0 0 0-17.6Zm0 2.4a6.4 6.4 0 1 1 0 12.8 6.4 6.4 0 0 1 0-12.8Zm-.1 2.8c-1.8 0-3.1 1.1-3.3 2.8h2.4c.1-.5.5-.8 1-.8.7 0 1.1.4 1.1 1 0 .4-.2.8-.7 1.1-.9.6-1.7 1.2-1.7 2.6v.2h2.3c0-.7.2-1 .9-1.5.8-.5 1.6-1.3 1.6-2.6 0-1.8-1.5-2.8-3.6-2.8Zm-.1 8.8a1.3 1.3 0 1 0 0 2.6 1.3 1.3 0 0 0 0-2.6Z"></path>
					</svg>
					<div class="fw-bold ">Anónimo</div>
				</a>

				<a href="{{ path('app_webhook_inicio', {tipo: 'no_cliente'}) }}" id="no_clientes" class=" {{ tipoUsuarioActual == 'no_cliente' ? 'active' : '' }} nav-link rounded-5 py-2 d-flex justify-content-center align-items-center gap-1" type="button">
					<svg width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
					<div class="fw-bold">No Clientes</div>
				</a>

				<a href="{{ path('app_webhook_inicio', {tipo: 'cliente'}) }}" id="clientes" class=" {{ tipoUsuarioActual == 'cliente' ? 'active' : '' }} nav-link rounded-5 py-2 d-flex justify-content-center align-items-center gap-1" >
					<svg width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
					<div class="fw-bold">Clientes</div>
				</a>
			</div>
		</div>

		<div class="d-flex gap-5 mt-2 nav nav-pills nav-fill bg-light rounded-5 shadow" id="pills-tab" role="tablist">
			<button id="ia" type="button" class="{{ tipoInteraccionActual == 'ia' ? 'active' : '' }} nav-link rounded-5 py-2 d-flex justify-content-center align-items-center gap-1" style="width: 350px;">
				<svg width="32" height="32" fill="currentColor" viewbox="0 0 24 24">
					<path d="M12 3L14.5 9.5L21 12L14.5 14.5L12 21L9.5 14.5L3 12L9.5 9.5L12 3Z"/><path d="M19 4L20 6.5L22.5 7.5L20 8.5L19 11L18 8.5L15.5 7.5L18 6.5L19 4Z"/><path d="M5 14L6 16.5L8.5 17.5L6 18.5L5 21L4 18.5L1.5 17.5L4 16.5L5 14Z"/>
				</svg>
				<span class="small fw-bold">IA</span>
			</button>

			<button id="teclado" class="{{ tipoInteraccionActual == 'teclado' ? 'active' : '' }} nav-link rounded-5 py-2 d-flex justify-content-center align-items-center gap-1" type="button" style="width: 350px;">
				<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewbox="0 0 24 24">
					<line x1="4" y1="9" x2="20" y2="9"></line>
					<line x1="4" y1="15" x2="20" y2="15"></line>
					<line x1="10" y1="3" x2="8" y2="21"></line>
					<line x1="16" y1="3" x2="14" y2="21"></line>
				</svg>
				<span class="small fw-bold">Teclado</span>
			</button>
		</div>

		<div id="iaPrompt" class="w-100 mt-5 {{ tipoInteraccionActual == 'ia' ? '' : 'd-none' }}">
			{{ form_label(configForm.prompt, 'Prompt de IA', {
				label_attr: { class: 'form-label fs-5 fw-bold mb-3' }
			}) }}
			{{ form_widget(configForm.prompt, {
				'label': false,
				attr: { class: 'form-control form-control-lg rounded-3 shadow-sm border-2', style: 'min-height: 200px; max-height: 900px; resize: vertical;' }
			}) }}
		</div>
		{% set molde = macros.render_fila(configForm.opcionDesplegable.vars.prototype) %}
		<div id="formularioOpciones" class="{{ tipoInteraccionActual == 'teclado' ? '' : 'd-none' }}">
			<div class="d-flex justify-content-between align-items-center mt-5 mb-4">
				<h3 class="fw-bold text-dark mb-0">Opciones del Menú</h3>
				<button type="button" class="btn btn-primary btn-lg" id="agregar_opcion">
					Agregar Opción
				</button>
			</div>
			<div id="contenedor_coleccion" class="d-flex flex-column gap-4" data-prototype="{{ molde|e('html_attr') }}" data-index="{{ configForm.opcionDesplegable|length }}">
				{% for campo in configForm.opcionDesplegable %}
					{{ macros.render_fila(campo) }}
				{% endfor %}
			</div>
		</div>

		<div class="d-flex justify-content-center gap-3 mt-5 mb-5">
			<button type="submit" onclick=" return confirm('¿Estas seguro de querer guardar los cambios? \nEn caso de que haya decidido cambiar de ia a teclado o viceversa se borrará toda la configuración anterior');" class="btn btn-success btn-lg fw-bold">Guardar</button>
			<a href="javascript:history.back()" onclick=" return confirm('¿Estás seguro? Se perderán los cambios no guardados.');" class="btn btn-secondary btn-lg fw-bold">Cancelar</a>
		</div>

		{{ form_end(configForm, {'render_rest': false}) }}

		{% macro render_fila(campo) %}
			<div class="opcion_bloque border border-1 p-4 rounded-3 mb-5 bg-white shadow-sm">
				<div class="row g-3 mb-4">
					<div class="col-md-2 d-flex flex-column align-items-center contenedor_tecla">
						<small class="text-muted fw-600 d-block mb-2">Tecla</small>
						{{ form_widget(campo.tecla, {
							'label': false,
							attr: { 
								class: 'form-control fw-bold text-center border-2', 
								style: 'width: 50px; height: 50px; font-size: 24px; display: flex; align-items: center; justify-content: center;'
							}
						}) }}
					</div>
					<div class="col-md-5 d-flex flex-column">
						<small class="text-muted fw-600 d-block mb-2">Etiqueta</small>
						{{ form_widget(campo.label, {
							'label': false,
							attr: { 
								class: 'form-control form-control-lg',
								style: 'font-size: 18px;'
							}
						}) }}
					</div>
					<div class="col-md-5 d-flex flex-column">
						<small class="text-muted fw-600 d-block mb-2">Submenú</small>
						{{ form_widget(campo.desplegable, {
							'label': false,
							attr: { 
								class: 'desplegable form-control form-control-lg',
								style: 'font-size: 18px;'
							}
						}) }}
					</div>
				</div>

				<div class="mt-4">
					{{ form_widget(campo.numeroAgente, {
						'label': false,
						attr: { class: 'form-control d-none numeroAgente' }
					}) }}
					{{ form_widget(campo.mensajePersonalizado, {
						'label': false,
						attr: { class: 'form-control d-none mensajePersonalizado' }
					}) }}
					{{ form_widget(campo.mensajeInicial, {
						'label': false,
						attr: { class: 'form-control d-none mensajeInicial' }
					}) }}
					{% if campo.submenu is defined %}
						<div class="d-none submenu_contenedor border-start border-primary border-4 ps-4 ms-3 mt-4 p-4 rounded-2" style="background-color: #f8f9fa;">
							<div class="d-flex justify-content-between align-items-center mb-3">
								<h6 class="fw-bold text-primary mb-0">Submenú</h6>
								<button type="button" class="btn btn-sm btn-primary agregar_subopcion">+ Agregar</button>
							</div>

							<div class="subcontenedor_molde d-flex flex-column gap-4" data-index="{{ campo.submenu|length }}" data-prototype="{{ _self.render_fila(campo.submenu.vars.prototype)|e('html_attr') }}">
								{% for subcampo in campo.submenu %}
									{{ _self.render_fila(subcampo) }}
								{% endfor %}
							</div>
						</div>
					{% endif %}
				</div>
				<button type="button" class="btn btn-danger mt-4" onclick="eliminarFila(this)">Eliminar Opción</button>
			</div>
		{% endmacro %}
		<script>let TIPO_ACTUAL = "{{ tipoInteraccionActual }}"</script>
		<script src="/js/configCall.js" defer></script>
	{% endblock %}
